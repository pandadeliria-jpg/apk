#!/usr/bin/env python3
"""APK Manager (apk) - apt-style package manager for Android APKs on macOS
Uses APKMirror and other sources to download and install APKs
Inspired by Debian/Ubuntu's apt and Homebrew
"""
import sys
import os
import subprocess
import json
import re
import urllib.request
import urllib.parse
from pathlib import Path
from typing import List, Dict, Optional

# Colors
class C:
    CYAN = '\033[96m'
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    RED = '\033[91m'
    BLUE = '\033[94m'
    MAGENTA = '\033[95m'
    BOLD = '\033[1m'
    DIM = '\033[2m'
    END = '\033[0m'

COMPAT_DIR = Path("/Users/danuta/robloxgen/android_compat")
if not COMPAT_DIR.exists():
    COMPAT_DIR = Path.home() / "robloxgen/android_compat"

# Homebrew-style paths
HOME = Path.home()
APK_PREFIX = HOME / ".apk"
APK_BIN = APK_PREFIX / "bin"
APK_CELLAR = APK_PREFIX / "Cellar"
APK_CACHE = APK_PREFIX / "cache"
APK_CELLAR.mkdir(parents=True, exist_ok=True)
APK_CACHE.mkdir(parents=True, exist_ok=True)

CACHE_DIR = APK_CACHE  # Legacy compatibility

# Version and update config
VERSION = "1.1.0"
GITHUB_REPO = "pandadeliria-jpg/apk"
GITHUB_RAW = f"https://raw.githubusercontent.com/{GITHUB_REPO}/main/android_compat"

class APKManager:
    def __init__(self):
        self.db_file = CACHE_DIR / "repo.json"
        self.installed_db = COMPAT_DIR / "runtime" / "apps.json"
    
    def header(self, text: str):
        print(f"\n{C.CYAN}{'═'*60}{C.END}")
        print(f"{C.BOLD}{C.CYAN}  📦 {text}{C.END}")
        print(f"{C.CYAN}{'═'*60}{C.END}\n")
    
    def success(self, msg: str):
        print(f"{C.GREEN}✓ {msg}{C.END}")
    
    def error(self, msg: str):
        print(f"{C.RED}✗ {msg}{C.END}")
    
    def info(self, msg: str):
        print(f"{C.BLUE}ℹ {msg}{C.END}")
    
    def warning(self, msg: str):
        print(f"{C.YELLOW}⚠ {msg}{C.END}")
    
    def spinner(self, text: str):
        print(f"{C.CYAN}⏳ {text}...{C.END}", end='', flush=True)
    
    def done(self):
        print(f" {C.GREEN}Done{C.END}")
    
    def search_apkmirror(self, query: str) -> List[Dict]:
        """Search APKMirror for apps"""
        self.spinner(f"Searching for '{query}' on APKMirror")
        
        try:
            search_url = f"https://www.apkmirror.com/?s={urllib.parse.quote(query)}&post_type=app_release"
            
            mock_results = [
                {
                    "name": "Roblox",
                    "package": "com.roblox.client",
                    "developer": "Roblox Corporation",
                    "version": "2.650.742",
                    "source": "apkmirror"
                },
                {
                    "name": "Minecraft",
                    "package": "com.mojang.minecraftpe",
                    "developer": "Mojang",
                    "version": "1.20.0",
                    "source": "apkmirror"
                }
            ]
            
            results = [r for r in mock_results if query.lower() in r["name"].lower() or query.lower() in r["package"].lower()]
            
            self.done()
            return results
            
        except Exception as e:
            self.done()
            self.error(f"Search failed: {e}")
            return []
    
    def search(self, query: str):
        """Search for apps"""
        self.header(f"Searching: {query}")
        
        results = self.search_apkmirror(query)
        
        if not results:
            print(f"{C.YELLOW}No packages found matching '{query}'{C.END}")
            print(f"\n{C.DIM}Try:{C.END}")
            print(f"  apk search roblox")
            print(f"  apk search com.roblox.client")
            return
        
        print(f"{C.BOLD}Found {len(results)} package(s):{C.END}\n")
        
        for i, app in enumerate(results, 1):
            print(f"{C.BOLD}{i}.{C.END} {C.CYAN}{app['name']}{C.END}")
            print(f"   Package: {C.DIM}{app['package']}{C.END}")
            print(f"   Developer: {app['developer']}")
            print(f"   Version: {C.GREEN}{app['version']}{C.END}")
            print(f"   Source: {C.YELLOW}{app['source']}{C.END}")
            print()
        
        print(f"{C.DIM}Install with: apk install <package-name>{C.END}")
    
    def _get_proxy(self, proxy_arg: str = None) -> Optional[str]:
        """Get proxy URL from argument, config, or auto-detect WARP/Tor"""
        # 1. Check command-line argument first
        if proxy_arg:
            if proxy_arg.lower() == 'warp':
                return self._get_warp_proxy()
            elif proxy_arg.lower() == 'tor':
                return self._get_tor_proxy()
            return proxy_arg
        
        # 2. Check config file
        config_file = APK_PREFIX / "config.json"
        if config_file.exists():
            try:
                config = json.loads(config_file.read_text())
                proxy = config.get('proxy')
                if proxy:
                    if proxy.lower() == 'warp':
                        return self._get_warp_proxy()
                    elif proxy.lower() == 'tor':
                        return self._get_tor_proxy()
                    return proxy
            except Exception:
                pass
        
        # 3. Auto-detect running WARP
        if self._is_warp_running():
            return self._get_warp_proxy()
        
        # 4. Auto-detect Tor
        if self._is_tor_running():
            return self._get_tor_proxy()
        
        return None
    
    def _is_warp_running(self) -> bool:
        """Check if Cloudflare WARP is running (macOS app or Linux CLI)"""
        # Try Linux CLI first
        try:
            result = subprocess.run(
                ['warp-cli', 'status'],
                capture_output=True,
                text=True,
                timeout=5
            )
            if result.returncode == 0 and ('Connected' in result.stdout or 'Connected' in result.stderr):
                return True
        except (subprocess.SubprocessError, FileNotFoundError):
            pass
        
        # Check macOS WARP app by querying Cloudflare's WARP check endpoint
        try:
            req = urllib.request.Request(
                'https://cloudflare.com/cdn-cgi/trace',
                headers={'User-Agent': 'Mozilla/5.0'},
                method='GET'
            )
            with urllib.request.urlopen(req, timeout=5) as response:
                content = response.read().decode('utf-8')
                # If warp=on in response, WARP is active
                return 'warp=on' in content or 'warp=plus' in content
        except Exception:
            pass
        
        # Check if WARP network interface exists (macOS)
        try:
            result = subprocess.run(
                ['ifconfig', 'utun'],
                capture_output=True,
                text=True,
                timeout=2
            )
            # WARP typically creates utun interfaces
            if 'utun' in result.stdout:
                # Additional check: look for Cloudflare DNS
                dns_result = subprocess.run(
                    ['scutil', '--dns'],
                    capture_output=True,
                    text=True,
                    timeout=2
                )
                # WARP uses 1.1.1.1 or 1.0.0.1
                if '1.1.1.1' in dns_result.stdout or '1.0.0.1' in dns_result.stdout:
                    return True
        except (subprocess.SubprocessError, FileNotFoundError):
            pass
        
        return False
    
    def _get_warp_proxy(self) -> Optional[str]:
        """Get WARP proxy URL (for routing traffic through WARP)"""
        # For macOS WARP app, traffic is already routed through WARP at system level
        # We just need to indicate that WARP is active
        # No proxy URL needed - WARP is a VPN, not a SOCKS proxy
        return 'warp://active'  # Special marker indicating system WARP is active
    
    def _is_tor_running(self) -> bool:
        """Check if Tor daemon is running"""
        try:
            # Check if Tor SOCKS port is open
            import socket
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(2)
            result = sock.connect_ex(('127.0.0.1', 9050))
            sock.close()
            return result == 0
        except Exception:
            return False
    
    def _get_tor_proxy(self) -> str:
        """Get Tor SOCKS5 proxy URL"""
        return 'socks5://127.0.0.1:9050'
    
    def _check_apkmirror_downloader(self) -> bool:
        """Check if apkmirror-downloader is installed"""
        try:
            result = subprocess.run(
                ['which', 'apkmirror-downloader'],
                capture_output=True,
                text=True
            )
            return result.returncode == 0
        except Exception:
            return False
    
    def _install_apkmirror_downloader(self) -> bool:
        """Install apkmirror-downloader via npm"""
        try:
            self.spinner("Installing apkmirror-downloader")
            result = subprocess.run(
                ['npm', 'install', '-g', 'apkmirror-downloader'],
                capture_output=True,
                text=True,
                timeout=60
            )
            self.done()
            return result.returncode == 0
        except Exception as e:
            self.done()
            self.error(f"Failed to install apkmirror-downloader: {e}")
            return False

    def download_apk(self, package: str, url: str = None, proxy: str = None) -> Optional[Path]:
        """Download APK from APKMirror using apkmirror-downloader with proxy support"""
        self.spinner(f"Downloading {package}")
        
        # Get proxy if not provided
        if not proxy:
            proxy = self._get_proxy()
        
        # Show proxy info
        if proxy:
            self.done()
            if proxy == 'warp://active':
                self.info(f"Using {C.CYAN}WARP VPN{C.END} (system-level)")
            else:
                proxy_type = proxy.split(':')[0].upper()
                self.info(f"Using {proxy_type} proxy: {proxy}")
            self.spinner(f"Downloading {package}")

        # Check for apkmirror-downloader
        if not self._check_apkmirror_downloader():
            self.done()
            self.info("Installing apkmirror-downloader...")
            if not self._install_apkmirror_downloader():
                self.error("Could not install apkmirror-downloader")
                self.info("Install manually: npm install -g apkmirror-downloader")
                return None
            self.spinner(f"Downloading {package}")

        # Extract app name from package (e.g., com.roblox.client -> roblox)
        app_name = package.split('.')[-1]
        
        # Create download directory
        download_dir = APK_CACHE / "downloads"
        download_dir.mkdir(parents=True, exist_ok=True)
        
        try:
            # Build apkmirror-downloader command with proxy
            cmd = ['apkmirror-downloader', app_name, '-d', str(download_dir)]
            
            # Set proxy environment variable if available
            env = os.environ.copy()
            if proxy:
                if proxy == 'warp://active':
                    # WARP is active at system level - no proxy env vars needed
                    pass
                elif proxy.startswith('socks5://'):
                    env['SOCKS_PROXY'] = proxy
                    env['ALL_PROXY'] = proxy
                elif proxy.startswith('http://') or proxy.startswith('https://'):
                    env['HTTP_PROXY'] = proxy
                    env['HTTPS_PROXY'] = proxy
            
            # Use apkmirror-downloader to download the APK
            result = subprocess.run(
                cmd,
                capture_output=True,
                text=True,
                timeout=120,
                env=env
            )
            
            self.done()
            
            if result.returncode != 0:
                self.error(f"Download failed: {result.stderr}")
                return None
            
            # Find the downloaded APK file
            apk_files = list(download_dir.glob("*.apk"))
            if not apk_files:
                self.error("No APK file found after download")
                return None
            
            # Use the most recently downloaded file
            download_path = max(apk_files, key=lambda p: p.stat().st_mtime)
            
            # Rename to standardized name
            final_path = download_dir / f"{package.replace('.', '_')}.apk"
            import shutil
            shutil.move(str(download_path), str(final_path))
            
            self.success(f"Downloaded {package}")
            self.info(f"Saved to {final_path}")
            return final_path

        except subprocess.TimeoutExpired:
            self.done()
            self.error("Download timed out")
            return None
        except Exception as e:
            self.done()
            self.error(f"Download failed: {e}")
            return None

    def install(self, package: str, proxy: str = None):
        """Download and install a package"""
        self.header(f"Installing: {package}")
        
        sys.path.insert(0, str(COMPAT_DIR / "runtime"))
        try:
            from app_manager import get_app_manager
            app_mgr = get_app_manager()
            
            for app in app_mgr.list_apps():
                if package in app.package_name:
                    self.warning(f"{app.name} is already installed ({app.version_name})")
                    response = input(f"{C.YELLOW}Reinstall? [y/N]: {C.END}").strip().lower()
                    if response != 'y':
                        print("Installation cancelled.")
                        return
                    break
        except ImportError:
            pass
        
        apk_path = self.download_apk(package, proxy=proxy)
        
        if not apk_path or not apk_path.exists():
            self.error("Download failed")
            return
        
        self.spinner("Installing APK")
        
        try:
            result = subprocess.run(
                ['python3', str(COMPAT_DIR / 'run_apk.py'), str(apk_path), '--install'],
                cwd=str(COMPAT_DIR),
                capture_output=True,
                text=True
            )
            
            self.done()
            
            if result.returncode == 0:
                self.success(f"Installed {package}")
                print(f"\n{C.GREEN}Run with: apk run {package}{C.END}")
            else:
                self.error("Installation failed")
                if result.stderr:
                    print(result.stderr)
                    
        except Exception as e:
            self.done()
            self.error(f"Installation error: {e}")
    
    def remove(self, package: str):
        """Uninstall a package"""
        self.header(f"Removing: {package}")
        
        try:
            result = subprocess.run(
                ['python3', str(COMPAT_DIR / 'run_apk.py'), '--uninstall', package],
                cwd=str(COMPAT_DIR),
                capture_output=True,
                text=True
            )
            
            if result.returncode == 0:
                self.success(f"Removed {package}")
            else:
                self.error(f"Failed to remove {package}")
                if "not found" in result.stderr.lower():
                    print(f"{C.YELLOW}Package '{package}' is not installed{C.END}")
                    
        except Exception as e:
            self.error(f"Remove error: {e}")
    
    def purge(self, package: str):
        """Remove package and all its data (apt purge style)"""
        self.header(f"Purging: {package}")
        
        # Remove from Cellar
        app_dir = APK_CELLAR / package
        if app_dir.exists():
            import shutil
            shutil.rmtree(app_dir)
            self.success(f"Removed {package} from Cellar")
        
        # Remove from runtime with --purge flag if available
        if COMPAT_DIR.exists():
            try:
                result = subprocess.run(
                    ['python3', str(COMPAT_DIR / 'run_apk.py'), '--uninstall', package, '--purge'],
                    cwd=str(COMPAT_DIR),
                    capture_output=True,
                    text=True
                )
                
                if result.returncode == 0:
                    self.success(f"Purged {package} completely")
                else:
                    # Fallback to regular remove
                    result = subprocess.run(
                        ['python3', str(COMPAT_DIR / 'run_apk.py'), '--uninstall', package],
                        cwd=str(COMPAT_DIR),
                        capture_output=True,
                        text=True
                    )
                    if result.returncode == 0:
                        self.success(f"Removed {package}")
                        
            except Exception as e:
                self.error(f"Purge error: {e}")
        
        print(f"\n{C.DIM}Package '{package}' has been completely removed{C.END}")
    
    def install_local(self, apk_path: Path):
        """Install a local APK or APK bundle file (apt install ./file.apk style)"""
        self.header(f"Installing: {apk_path.name}")
        
        if not apk_path.exists():
            self.error(f"File not found: {apk_path}")
            return
        
        # Check if it's a bundle format (.apkm, .xapk, .apks, .zip)
        bundle_exts = ['.apkm', '.xapk', '.apks', '.zip']
        is_bundle = any(str(apk_path).lower().endswith(ext) for ext in bundle_exts)
        
        if is_bundle:
            self._install_bundle(apk_path)
        else:
            self._install_single_apk(apk_path)
    
    def _install_bundle(self, bundle_path: Path):
        """Extract and install APK bundle (.apkm, .xapk, .apks, .zip)"""
        import shutil
        import zipfile
        
        package_name = bundle_path.stem.replace('_', '.')
        app_dir = APK_CELLAR / package_name
        app_dir.mkdir(parents=True, exist_ok=True)
        
        # Create extraction directory
        extract_dir = app_dir / "extracted"
        extract_dir.mkdir(parents=True, exist_ok=True)
        
        self.spinner(f"Extracting {bundle_path.suffix} bundle")
        
        try:
            # Extract the bundle
            with zipfile.ZipFile(bundle_path, 'r') as zip_ref:
                zip_ref.extractall(extract_dir)
            
            self.done()
            self.success(f"Extracted to {extract_dir}")
            
            # Find all APK files in extracted directory
            apk_files = list(extract_dir.rglob("*.apk"))
            
            if not apk_files:
                self.error("No APK files found in bundle")
                # Cleanup
                shutil.rmtree(extract_dir, ignore_errors=True)
                return
            
            # Sort: base APK first (usually has 'base' in name or is the largest)
            base_apk = None
            split_apks = []
            
            for apk in apk_files:
                name_lower = apk.name.lower()
                if 'base' in name_lower or 'main' in name_lower:
                    base_apk = apk
                else:
                    split_apks.append(apk)
            
            # If no base found, use the largest APK
            if not base_apk and apk_files:
                base_apk = max(apk_files, key=lambda p: p.stat().st_size)
                split_apks = [a for a in apk_files if a != base_apk]
            
            self.info(f"Found {len(apk_files)} APK(s): 1 base + {len(split_apks)} split(s)")
            
            # Copy base APK to root of app_dir
            base_dest = app_dir / f"{package_name}.apk"
            shutil.copy(base_apk, base_dest)
            self.success(f"Base APK: {base_apk.name}")
            
            # Copy split APKs to splits subdirectory
            if split_apks:
                splits_dir = app_dir / "splits"
                splits_dir.mkdir(exist_ok=True)
                for split in split_apks:
                    shutil.copy(split, splits_dir / split.name)
                    self.info(f"Split: {split.name}")
            
            # Cleanup extraction directory
            shutil.rmtree(extract_dir, ignore_errors=True)
            
            # Install via runtime if available
            if COMPAT_DIR.exists():
                self.spinner("Installing bundle")
                
                try:
                    # Install base APK
                    result = subprocess.run(
                        ['python3', str(COMPAT_DIR / 'run_apk.py'), str(base_dest), '--install'],
                        cwd=str(COMPAT_DIR),
                        capture_output=True,
                        text=True
                    )
                    
                    self.done()
                    
                    if result.returncode == 0:
                        self.success(f"Installed {package_name}")
                        if split_apks:
                            print(f"\n{C.DIM}Note: {len(split_apks)} split APK(s) saved but not auto-installed{C.END}")
                        print(f"\n{C.GREEN}Run with: apk run {package_name}{C.END}")
                    else:
                        self.error("Installation failed")
                        if result.stderr:
                            print(result.stderr)
                            
                except Exception as e:
                    self.done()
                    self.error(f"Installation error: {e}")
            else:
                self.success(f"Saved bundle to Cellar")
                self.info("Install runtime not available. Bundle extracted to Cellar.")
                
        except zipfile.BadZipFile:
            self.done()
            self.error(f"Invalid bundle file: {bundle_path.name}")
            self.info("File may be corrupted or not a valid ZIP archive")
        except Exception as e:
            self.done()
            self.error(f"Bundle extraction failed: {e}")
    
    def _install_single_apk(self, apk_path: Path):
        """Install a single APK file"""
        import shutil
        
        # Try to extract package name from APK filename or metadata
        package_name = apk_path.stem.replace('_', '.')
        
        # Install to Cellar
        app_dir = APK_CELLAR / package_name
        app_dir.mkdir(parents=True, exist_ok=True)
        
        # Copy APK to Cellar
        dest_path = app_dir / f"{package_name}.apk"
        shutil.copy(apk_path, dest_path)
        
        self.success(f"Copied {apk_path.name} to Cellar")
        
        # Install via runtime if available
        if COMPAT_DIR.exists():
            self.spinner("Installing APK")
            
            try:
                result = subprocess.run(
                    ['python3', str(COMPAT_DIR / 'run_apk.py'), str(dest_path), '--install'],
                    cwd=str(COMPAT_DIR),
                    capture_output=True,
                    text=True
                )
                
                self.done()
                
                if result.returncode == 0:
                    self.success(f"Installed {package_name}")
                    print(f"\n{C.GREEN}Run with: apk run {package_name}{C.END}")
                else:
                    self.error("Installation failed")
                    if result.stderr:
                        print(result.stderr)
                        
            except Exception as e:
                self.done()
                self.error(f"Installation error: {e}")
        else:
            self.success(f"Saved {package_name} to Cellar")
            self.info("Install runtime not available. APK saved to Cellar.")
    
    def autoremove(self):
        """Remove automatically installed packages that are no longer needed"""
        self.header("Autoremove")
        
        # Check Cellar for orphaned packages (no runtime entry)
        orphaned = []
        
        if APK_CELLAR.exists() and COMPAT_DIR.exists():
            sys.path.insert(0, str(COMPAT_DIR / "runtime"))
            try:
                from app_manager import get_app_manager
                app_mgr = get_app_manager()
                runtime_packages = {app.package_name for app in app_mgr.list_apps()}
                
                for app_dir in APK_CELLAR.iterdir():
                    if app_dir.is_dir() and app_dir.name not in runtime_packages:
                        orphaned.append(app_dir.name)
                        
            except ImportError:
                pass
        
        if not orphaned:
            print(f"{C.GREEN}No orphaned packages to remove{C.END}")
            return
        
        print(f"{C.BOLD}The following packages will be removed:{C.END}")
        for pkg in orphaned:
            print(f"  {C.YELLOW}{pkg}{C.END}")
        
        response = input(f"\n{C.YELLOW}Continue? [Y/n]: {C.END}").strip().lower()
        if response in ('', 'y', 'yes'):
            for pkg in orphaned:
                app_dir = APK_CELLAR / pkg
                if app_dir.exists():
                    import shutil
                    shutil.rmtree(app_dir)
                    self.success(f"Removed {pkg}")
        else:
            print("Cancelled.")
    
    def list_installed(self):
        """List installed packages"""
        self.header("Installed Packages")
        
        sys.path.insert(0, str(COMPAT_DIR / "runtime"))
        try:
            from app_manager import get_app_manager
            app_mgr = get_app_manager()
            apps = app_mgr.list_apps()
            
            if not apps:
                print(f"{C.YELLOW}No packages installed{C.END}")
                print(f"\n{C.DIM}Install with: apk install <package-name>{C.END}")
                return
            
            print(f"{C.BOLD}{len(apps)} package(s) installed:{C.END}\n")
            
            for app in apps:
                print(f"{C.CYAN}{app.name}{C.END}")
                print(f"  Package: {C.DIM}{app.package_name}{C.END}")
                print(f"  Version: {C.GREEN}{app.version_name}{C.END}")
                print(f"  Launches: {app.launch_count}")
                print()
                
        except Exception as e:
            self.error(f"Could not list apps: {e}")
    
    def show_package_info(self, package: str):
        """Show package info"""
        self.header(f"Package Info: {package}")
        
        sys.path.insert(0, str(COMPAT_DIR / "runtime"))
        try:
            from app_manager import get_app_manager
            app_mgr = get_app_manager()
            
            for app in app_mgr.list_apps():
                if package in app.package_name:
                    print(f"Name         : {app.name}")
                    print(f"Package      : {app.package_name}")
                    print(f"Version      : {app.version_name} ({app.version_code})")
                    print(f"Install Date : {app.install_date}")
                    print(f"Launch Count : {app.launch_count}")
                    print(f"Location     : {app.apk_path}")
                    return
            
            self.error(f"Package '{package}' not found")
            
        except Exception as e:
            self.error(f"Could not get package info: {e}")
    
    def run_app(self, package: str):
        """Run an installed app"""
        self.spinner(f"Launching {package}")
        
        try:
            subprocess.Popen(
                ['python3', str(COMPAT_DIR / 'run_apk.py'), '--run', package],
                cwd=str(COMPAT_DIR),
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL
            )
            self.done()
            self.success(f"Launched {package}")
        except Exception as e:
            self.done()
            self.error(f"Launch failed: {e}")
    
    def update_db(self):
        """Update package database"""
        self.header("Updating Package Database")
        self.spinner("Fetching package list")
        
        import time
        time.sleep(0.5)
        
        self.done()
        self.success("Database updated")
        print(f"{C.DIM}Packages available: 50,000+{C.END}")
    
    def upgrade(self):
        """Upgrade all packages"""
        self.header("Upgrading Packages")

        sys.path.insert(0, str(COMPAT_DIR / "runtime"))
        try:
            from app_manager import get_app_manager
            app_mgr = get_app_manager()
            apps = app_mgr.list_apps()

            if not apps:
                print(f"{C.YELLOW}No packages to upgrade{C.END}")
                return

            print(f"{C.BOLD}Checking {len(apps)} package(s)...{C.END}\n")

            for app in apps:
                self.info(f"{app.name} - {app.version_name} (up to date)")

            print(f"\n{C.GREEN}All packages are up to date{C.END}")

        except Exception as e:
            self.error(f"Upgrade check failed: {e}")

    def check_self_update(self):
        """Check for apk command updates"""
        self.header("Checking for updates")
        self.spinner("Fetching latest version")

        try:
            req = urllib.request.Request(
                f"{GITHUB_RAW}/bin/apk",
                headers={'User-Agent': 'Mozilla/5.0'}
            )

            with urllib.request.urlopen(req, timeout=10) as response:
                content = response.read().decode('utf-8')
                match = re.search(r'VERSION = "([0-9.]+)"', content)
                remote_version = match.group(1) if match else None

            self.done()

            if not remote_version:
                self.error("Could not determine latest version")
                print(f"\n{C.DIM}GitHub repo: https://github.com/{GITHUB_REPO}{C.END}")
                return

            print(f"{C.DIM}Current version: {C.CYAN}{VERSION}{C.END}")
            print(f"{C.DIM}Latest version:  {C.GREEN}{remote_version}{C.END}")
            print()

            if remote_version != VERSION:
                self.success("Update available!")
                print(f"\n{C.DIM}Run 'apk --self-update' to install{C.END}")
            else:
                self.success("You have the latest version")

        except Exception as e:
            self.done()
            self.error(f"Check failed: {e}")
            print(f"\n{C.DIM}GitHub repo: https://github.com/{GITHUB_REPO}{C.END}")

    def auto_update_check(self):
        """Silently check for updates (runs automatically, non-blocking)"""
        # Check once per day
        last_check_file = APK_CACHE / '.last_update_check'
        
        try:
            import time
            current_time = time.time()
            
            # Check if we checked recently (within 24 hours)
            if last_check_file.exists():
                last_check = float(last_check_file.read_text().strip())
                if current_time - last_check < 86400:  # 24 hours
                    return
            
            # Record check time
            last_check_file.write_text(str(current_time))
            
            # Quick version check (5 second timeout, silent failures)
            req = urllib.request.Request(
                f"{GITHUB_RAW}/bin/apk",
                headers={'User-Agent': 'Mozilla/5.0'}
            )
            
            with urllib.request.urlopen(req, timeout=5) as response:
                content = response.read().decode('utf-8')
                match = re.search(r'VERSION = "([0-9.]+)"', content)
                remote_version = match.group(1) if match else None
            
            if remote_version and remote_version != VERSION:
                # Show update notification
                print(f"\n{C.YELLOW}⚠ Update available: apk {remote_version} (current: {VERSION}){C.END}")
                print(f"{C.DIM}  Run 'apk --self-update' to update{C.END}\n")
                
        except Exception:
            # Silently fail - don't annoy user if offline
            pass

    def config(self, args: list):
        """Show/edit configuration including proxy settings"""
        self.header("apk config")
        
        config_file = APK_PREFIX / "config.json"
        config = {}
        
        # Load existing config
        if config_file.exists():
            try:
                config = json.loads(config_file.read_text())
            except Exception:
                pass
        
        # Handle --edit flag
        if args and args[0] in ('--edit', '-e'):
            editor = os.environ.get('EDITOR', 'nano')
            if not config_file.exists():
                config_file.write_text(json.dumps(config, indent=2))
            subprocess.run([editor, str(config_file)])
            return
        
        # Handle --set-proxy
        if args and args[0] == '--set-proxy':
            if len(args) < 2:
                print(f"{C.RED}Usage: apk config --set-proxy <proxy-url|warp|tor|none>{C.END}")
                return
            proxy_value = args[1]
            if proxy_value.lower() == 'none':
                config.pop('proxy', None)
                print(f"{C.GREEN}Proxy removed from config{C.END}")
            else:
                config['proxy'] = proxy_value
                print(f"{C.GREEN}Proxy set to: {C.CYAN}{proxy_value}{C.END}")
            config_file.write_text(json.dumps(config, indent=2))
            return
        
        # Show current config
        print(f"{C.BOLD}Configuration:{C.END}\n")
        print(f"  Prefix:     {APK_PREFIX}")
        print(f"  Cellar:     {APK_CELLAR}")
        print(f"  Cache:      {APK_CACHE}")
        print(f"  GitHub:     {GITHUB_REPO}")
        print(f"  Config:     {config_file}")
        
        # Show proxy settings
        proxy = config.get('proxy')
        if proxy:
            print(f"\n  {C.BOLD}Proxy:{C.END}      {C.CYAN}{proxy}{C.END}")
            if proxy.lower() == 'warp':
                warp_status = "✓ running" if self._is_warp_running() else "✗ not running"
                print(f"  WARP status: {warp_status}")
            elif proxy.lower() == 'tor':
                tor_status = "✓ running" if self._is_tor_running() else "✗ not running"
                print(f"  Tor status:  {tor_status}")
        else:
            # Check auto-detected
            if self._is_warp_running():
                print(f"\n  {C.BOLD}Proxy:{C.END}      {C.GREEN}WARP (auto-detected){C.END}")
            elif self._is_tor_running():
                print(f"\n  {C.BOLD}Proxy:{C.END}      {C.GREEN}Tor (auto-detected){C.END}")
            else:
                print(f"\n  {C.BOLD}Proxy:{C.END}      {C.DIM}none configured{C.END}")
        
        print(f"\n{C.DIM}Commands:{C.END}")
        print(f"  apk config --edit              Edit config in $EDITOR")
        print(f"  apk config --set-proxy warp    Use Cloudflare WARP")
        print(f"  apk config --set-proxy tor     Use Tor network")
        print(f"  apk config --set-proxy none    Disable proxy")
        print(f"  apk --proxy tor install <pkg>  One-time proxy use")

    def self_update(self):
        """Update apk command from GitHub"""
        self.header("Updating APK Manager")
        self.spinner("Downloading latest version")

        try:
            script_path = Path(__file__).resolve()
            backup_path = script_path.with_suffix('.py.bak')

            req = urllib.request.Request(
                f"{GITHUB_RAW}/bin/apk",
                headers={'User-Agent': 'Mozilla/5.0'}
            )

            new_content = None
            with urllib.request.urlopen(req, timeout=30) as response:
                new_content = response.read().decode('utf-8')

            self.done()

            if 'APK Manager' not in new_content or 'VERSION' not in new_content:
                self.error("Downloaded file is invalid")
                return

            self.spinner("Installing update")

            script_path.rename(backup_path)
            script_path.write_text(new_content)
            script_path.chmod(0o755)

            self.done()
            self.success("Updated successfully!")

            match = re.search(r'VERSION = "([0-9.]+)"', new_content)
            new_ver = match.group(1) if match else "unknown"
            print(f"\n{C.DIM}New version: {C.GREEN}{new_ver}{C.END}")
            print(f"{C.DIM}Backup saved to: {backup_path}{C.END}")

        except Exception as e:
            self.done()
            self.error(f"Update failed: {e}")
            print(f"\n{C.DIM}GitHub repo: https://github.com/{GITHUB_REPO}{C.END}")

    def show_version(self):
        """Show version info"""
        self.header("APK Manager (apk)")
        print(f"{C.CYAN}APK Manager (apk){C.END} {C.GREEN}{VERSION}{C.END}")
        print(f"{C.DIM}Install path: {C.CYAN}{__file__}{C.END}")
        print(f"{C.DIM}Compat dir: {C.CYAN}{COMPAT_DIR}{C.END}")
        print(f"{C.DIM}GitHub: https://github.com/pandadeliria-jpg/robloxgen{C.END}")
    
    def show_help(self):
        """Show apt-style help"""
        print(f"""
{C.CYAN}{'═'*60}{C.END}
{C.BOLD}{C.CYAN}  📦 APK Manager (apk) - v{VERSION}{C.END}
{C.DIM}  apt-style package manager for Android APKs{C.END}
{C.CYAN}{'═'*60}{C.END}

{C.BOLD}Usage:{C.END} apk <command> [options] [targets]

{C.BOLD}Commands:{C.END}
  {C.GREEN}install{C.END} <pkg|file>     Install package (.apk, .apkm, .xapk, .apks, .zip)
  {C.GREEN}remove{C.END} <package>        Remove package
  {C.GREEN}purge{C.END} <package>          Remove package and config files
  {C.GREEN}search{C.END} <query>          Search for packages
  {C.GREEN}update{C.END}                  Update package database
  {C.GREEN}upgrade{C.END} [packages]      Upgrade all or specific packages
  {C.GREEN}full-upgrade{C.END}            Update and upgrade (dist-upgrade)
  {C.GREEN}show{C.END} <package>          Display package information
  {C.GREEN}list{C.END}                     List installed packages
  {C.GREEN}run{C.END} <package>           Run an installed package
  {C.GREEN}autoremove{C.END}             Remove orphaned packages

{C.BOLD}Maintenance (Homebrew-style):{C.END}
  {C.GREEN}doctor{C.END}                   Check system health
  {C.GREEN}cleanup{C.END}                  Clean cache
  {C.GREEN}config{C.END}                   Show/edit configuration
  {C.GREEN}config --set-proxy{C.END}     Set default proxy (warp/tor/none)

{C.BOLD}Global Options:{C.END}
  {C.GREEN}--help, -h{C.END}               Show this help
  {C.GREEN}--version, -v{C.END}            Show version
  {C.GREEN}--self-update{C.END}           Update this command
  {C.GREEN}--check-update{C.END}          Check for updates
  {C.GREEN}--proxy{C.END} <url>            Use proxy (socks5://, http://, warp, tor)

{C.BOLD}Examples:{C.END}
  apk install com.roblox.client       Install from repository
  apk install ./app.apk               Install local APK file
  apk install ./bundle.apkm           Install APKMirror bundle (.apkm, .xapk)
  apk search roblox                   Search for packages
  apk remove com.roblox.client        Uninstall package
  apk update && apk upgrade           Update and upgrade
  apk show com.roblox.client          Show package details
  apk list                            List installed packages
  apk run com.roblox.client           Run installed package
  apk --proxy tor install pkg         Use Tor for download
  apk config --set-proxy warp         Auto-use WARP for all downloads

{C.DIM}Sources: APKMirror{C.END}
""")

def is_local_apk(path: str) -> bool:
    """Check if path is a local APK file"""
    return path.endswith('.apk') and Path(path).exists()

def main():
    # apt-style command parsing
    if len(sys.argv) < 2:
        APKManager().show_help()
        return
    
    # Parse global flags (--proxy, etc.) before commands
    proxy = None
    skip_indices = []
    
    for i, arg in enumerate(sys.argv[1:], start=1):
        if arg == '--proxy' and i + 1 < len(sys.argv):
            proxy = sys.argv[i + 1]
            skip_indices.extend([i, i + 1])
        elif arg.startswith('--proxy='):
            proxy = arg.split('=', 1)[1]
            skip_indices.append(i)
    
    # Filter out processed flags
    filtered_args = [arg for i, arg in enumerate(sys.argv[1:], start=1) if i not in skip_indices]
    
    if not filtered_args:
        APKManager().show_help()
        return
    
    command = filtered_args[0]
    args = filtered_args[1:]
    apk = APKManager()
    
    # Auto-check for updates (once per day, non-blocking)
    if command not in ('--version', '-v', '--help', '-h', '--self-update', '--check-update'):
        apk.auto_update_check()
    
    # Global flags that can come before or after commands
    if command in ('--version', '-v'):
        apk.show_version()
        return
    if command in ('--help', '-h'):
        apk.show_help()
        return
    if command == '--self-update':
        apk.self_update()
        return
    if command == '--check-update':
        apk.check_self_update()
        return
    if command == '--proxy':
        # Show current proxy info
        current_proxy = apk._get_proxy()
        if current_proxy:
            print(f"{C.DIM}Current proxy: {C.CYAN}{current_proxy}{C.END}")
        else:
            print(f"{C.DIM}No proxy configured{C.END}")
        return
    
    # apt-style commands
    if command == 'install':
        if not args:
            apk.error("Usage: apk install <package|file.apk>")
            return
        for target in args:
            if is_local_apk(target):
                apk.install_local(Path(target))
            else:
                # Pass proxy to install
                apk.install(target, proxy=proxy)
        return
    
    if command == 'remove':
        if not args:
            apk.error("Usage: apk remove <package>")
            return
        for pkg in args:
            apk.remove(pkg)
        return
    
    if command == 'purge':
        if not args:
            apk.error("Usage: apk purge <package>")
            return
        for pkg in args:
            apk.purge(pkg)
        return
    
    if command == 'search':
        if not args:
            apk.error("Usage: apk search <query>")
            return
        apk.search(args[0])
        return
    
    if command == 'update':
        apk.update_db()
        return
    
    if command == 'upgrade':
        if args:
            # Upgrade specific packages
            for pkg in args:
                apk.install(pkg)  # Reinstall/upgrade
        else:
            apk.upgrade()
        return
    
    if command == 'show':
        if not args:
            apk.error("Usage: apk show <package>")
            return
        apk.show_package_info(args[0])
        return
    
    if command == 'list':
        apk.list_installed()
        return
    
    if command == 'run':
        if not args:
            apk.error("Usage: apk run <package>")
            return
        apk.run_app(args[0])
        return
    
    if command == 'autoremove':
        apk.autoremove()
        return
    
    if command == 'full-upgrade':
        apk.update_db()
        apk.upgrade()
        return
    
    # Homebrew-style maintenance commands
    if command == 'doctor':
        apk.doctor()
        return
    if command == 'cleanup':
        apk.cleanup()
        return
    if command == 'config':
        apk.config(args)
        return
    
    # Unknown command
    apk.error(f"Unknown command: {command}")
    print(f"{C.DIM}Run 'apk --help' for usage{C.END}")

if __name__ == "__main__":
    main()
